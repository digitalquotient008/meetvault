# Database (Neon, Supabase, or any PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/meetingvault?sslmode=require"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# App URL (for redirects and links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (Phase 2)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: Resend (Phase 4)
# RESEND_API_KEY="re_..."

# Optional: Twilio SMS (Phase 4)
# TWILIO_ACCOUNT_SID="..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_PHONE_NUMBER="+1..."

# Optional: Use consultslot as MeetingVault backend (when set, public booking fetches shop from API)
# MEETINGVAULT_API_URL="https://your-consultslot-host.com"
# MEETINGVAULT_API_KEY="your-api-key"
